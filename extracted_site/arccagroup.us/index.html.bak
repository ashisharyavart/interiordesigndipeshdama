<style>/* widget: Ax Cursor Effect */

html {
  scroll-behavior: smooth;
}

#uc_ax_cursor_effect_elementor_d0cdf09 {
  position: fixed;
  z-index: 99;
  left: 0;
  top: 0;
  pointer-events: none;
  will-change: transform;
}
#uc_ax_cursor_effect_elementor_d0cdf09.difference {
  mix-blend-mode: difference;
}
#uc_ax_cursor_effect_elementor_d0cdf09.difference .cursor__circle {
  border: solid 2px rgba(227, 222, 193, 0.64);
}
#uc_ax_cursor_effect_elementor_d0cdf09.difference.overlay .cursor__circle {
  background-color: rgba(167, 165, 149, 0.12);
}
#uc_ax_cursor_effect_elementor_d0cdf09 .cursor__circle {
  margin-top: -50%;
  margin-left: -50%;
  border-radius: 50%;
  border: solid 2px rgba(28, 33, 62, 0.64);
  transition: opacity 0.3s cubic-bezier(0.25, 1, 0.5, 1), background-color 0.3s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.3s cubic-bezier(0.25, 1, 0.5, 1), width 0.3s cubic-bezier(0.25, 1, 0.5, 1), height 0.3s cubic-bezier(0.25, 1, 0.5, 1);
}
#uc_ax_cursor_effect_elementor_d0cdf09.subtle .cursor__circle {
  border-color: rgba(227, 222, 193, 0.16);
}
#uc_ax_cursor_effect_elementor_d0cdf09.arrow .cursor__circle {
  border:0;

}
#uc_ax_cursor_effect_elementor_d0cdf09.arrow::after {
  content: "";
  position: absolute;
  left: -50%;
  top: -50%;
  width: 100%;
  height: 100%;
  background-image: url("https://svgshare.com/i/MzQ.svg");
  background-repeat: no-repeat;
  background-position: center;
}
#uc_ax_cursor_effect_elementor_d0cdf09.overlay .cursor__circle {
  background-color: rgba(28, 33, 62, 0.16);
  border-color: transparent;
}

</style>

<div id="uc_ax_cursor_effect_elementor_d0cdf09" class="difference">
  <div class="cursor__circle"></div>
</div>
