<script type='module'>

/* Texto reveal scripts: */ 

gsap.registerPlugin(ScrollTrigger, SplitText);

window.addEventListener("DOMContentLoaded", () => {
  // When all the fonts are loaded
  document.fonts.ready.then(() => {
    init();
  });
});

function init() {
   const paragraph = document.querySelector(".p-19");
   const {lines} = new SplitText(paragraph, {type: "lines", linesClass: "line"});
  
  lines.forEach(line => {
    const originalLine = line;
    line.outerHTML = `<div class="mask">${originalLine.outerHTML}</div>`
  })

  //now animate each character into place from 100px above, fading in:
