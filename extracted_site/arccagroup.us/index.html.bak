<!--   Unlimited Elements 2.0.5 Scripts --> 
<script type='text/javascript' id='unlimited-elements-scripts'>

/* gsap menu scripts: */ 

window.addEventListener("DOMContentLoaded", () => {
  gsap.set(".menu", {
    autoAlpha:0,
  });

  const tl_menuReveal = gsap.timeline({
    paused: true,
    id: "menuReveal",
    defaults: {
      duration: 1,
      ease: "sine.out(5)",
    },
  });

  tl_menuReveal
    .set(".menu", {
      autoAlpha: 1,
    })
    .from(".menu-bg", {
      opacity: 0,
      duration: 0.5,
    })
    .from(
      ".menu-item-container",
      {
        x: gsap.utils.wrap(["-100%", "100%"]),
      },
      0
    )
    .from(
      ".menu-btn-close",
      {
        opacity: 0,
      },
      0.5
    )
    .from(
      ".menu .mask>*",
      {
        y: "110%",
        stagger: 0.01,
      },
      0.5
    )
    .from(
      ".menu .menu-line",
      {
        scaleX: 0,
        stagger: 0.1,
      },
      0.5
    )
    .from(
      ".menu-footer-logo",
      {
        opacity: 0,
      },
      0.5
    );

  const tl_menuClose = gsap.timeline({
    paused: true,
    defaults: {
      duration: 0.5,
      ease: "sine.out(1.5)",
    },
  });
  tl_menuClose
    .to(
      ".menu-item-container",
      {
        x: gsap.utils.wrap(["-100%", "100%"]),
      },
      0
    )
    .to(
      ".menu-btn-close",
      {
        duration: 0.5,
        opacity: 0,
      },
      0
    )
    .to(
      ".menu-bg",
      {
        opacity: 0,
      },
      0.3
    )
    .set(".menu", {
      autoAlpha: 0,
    });

  document.querySelector(".menu-btn-close").addEventListener("click", () => {
    tl_menuClose.restart();
  });
  document.querySelectorAll(".menu-button").forEach(button => {
  	button.addEventListener("click", () => {
      tl_menuReveal.restart();
    });
  })

  
});

/* Text Rotate Appear Slow scripts: */ 

document.addEventListener("DOMContentLoaded", function() {
  gsap.registerPlugin(SplitType, ScrollTrigger);
  let typeSplit = new SplitType('#uc_text_rotate_appear_slow_elementor_204741e [animate]', {
    types: 'lines, words, chars',
    tagName: 'span'
  })
  
  gsap.from('#uc_text_rotate_appear_slow_elementor_204741e [animate] .word', {
    y: '130%',
    opacity: 0,
    rotationZ: '10',
    duration: 0.6,
    ease: 'power1.out',
    stagger: 0.1,
    scrollTrigger: {
      trigger: '#uc_text_rotate_appear_slow_elementor_204741e [animate]',
      start: 'top 80%',
      toggleActions: 'play',
    }
  })
});

/* Scroll Image Reveal scripts: */ 

jQuery(document).ready(function(){
  
  	var objImageReveal = jQuery('#uc_image_reveal_on_scroll_elementor_993290b');
  	var objOverlay = objImageReveal.find('.uc_overlay');
  	var revealClass = 'uc_reveal';
  
    jQuery(objImageReveal).on('inview', function(event, isInView) {
      	
        if (isInView == true)
        objOverlay.addClass(revealClass);
      	
                
          if(isInView == false)
          objOverlay.removeClass(revealClass);
          
        	
      	
    });
});

/* Video Play Button scripts: */ 

jQuery(document).ready(function(){
  
var objVideoButton = jQuery("#uc_blox_play_button_elementor_a31f2ad");  

//fix for ios devices
jQuery(document).on('click.lity', function(){
 
   var objIframeContainer = jQuery(".lity-iframe-container");
   var objIframe = objIframeContainer.find("iframe");          
   
   setTimeout(function(){
     
      var isVideoSelfHosted = objVideoButton.data("path");
     
      if(isVideoSelfHosted != "self_hosted")
      return(false);
          
      var objVideo = objIframe.contents().find("video");
     	
      if(!objVideo.length)
      return(false);
     
      if(objVideo.hasClass("mac") || objVideo.hasClass("video") || objVideo.hasClass("audio")){
        
        objVideo.removeClass("mac");
        objVideo.removeClass("video");
        objVideo.removeClass("audio");
        
      }      
     
   },400);
  
    
});

});

/* loader curtail reveal gsap scripts: */ 

gsap.registerPlugin(DrawSVGPlugin) 


window.addEventListener("DOMContentLoaded", () => {
  // When all the fonts are loaded
  const lines = document.querySelectorAll(".loader__line");
  const lineThick = document.querySelectorAll(".loader__line_thick");
  const circle = document.querySelector(".loader__circle");
  const curtains = document.querySelectorAll(".curtain");

  const tl = gsap.timeline({
    defaults: {
      duration: 0.6,
      ease: "power2.inOut",
    },
  });
  tl.to(lines, {
    delay: 0.5,
    y: gsap.utils.wrap(["100%", "-100%"]),
  })
    .to(
      lineThick,
      {
        ease: "power1.Out",
        y: gsap.utils.wrap(["-100%", "100%"]),
      },
      "-=0.3"
    )
    .to(
      circle,
      {
        opacity: 0,
      },
      "-=0.3"
    )
    .to(
      curtains,
      {
        ease: "elegant",
        x: gsap.utils.wrap(["-100%", "100%"]),
        onComplete: () => {
          document.querySelector(".loader").style.display = "none";
        },
      },
      "-=0.2"
    )
   
});

