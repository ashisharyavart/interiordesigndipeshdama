<!-- start Creative Button Hovers -->
<style>/* widget: Creative Button Hovers */

#uc_creative_buttons_elementor_0ef256c.uc_creative_buttons .uc_button,
#uc_creative_buttons_elementor_0ef256c.uc_creative_buttons .uc_button::after,
#uc_creative_buttons_elementor_0ef256c .uc_creative_buttons_icon{
	transition: all 0.5s;
}

#uc_creative_buttons_elementor_0ef256c.uc_creative_buttons .uc_button {
  overflow:hidden;
}

#uc_creative_buttons_elementor_0ef256c .uc_button_wrapper{
  display: flex;
  align-items: center;
  justify-content: center;
}

/* start styles */
#uc_creative_buttons_elementor_0ef256c .uc_content{
  display: flex;
  flex-wrap: wrap;
}

/* GENERAL BUTTON STYLING */
#uc_creative_buttons_elementor_0ef256c .uc_button,
#uc_creative_buttons_elementor_0ef256c .uc_button::after {
	transition: all 0.3s;
}

#uc_creative_buttons_elementor_0ef256c .uc_button {
  margin: 0 auto;
  position: relative;
  text-align: center;
}

#uc_creative_buttons_elementor_0ef256c .uc_button span{
  z-index: 2;
  position: relative;
  display: block;
}

#uc_creative_buttons_elementor_0ef256c .uc_button::before,
#uc_creative_buttons_elementor_0ef256c .uc_button::after {
  content: '';
  position: absolute;
  z-index: 1;
}

/* BUTTON 1 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-1::after {
  height: 0;
  left: 0;
  top: 0;
  width: 100%;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-1:hover:after {
  height: 100%;
}

/* BUTTON 7 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-7::after {
  height: 0;
  left: 0;
  bottom: 0;
  width: 100%;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-7:hover:after {
  height: 100%;
}

/* BUTTON 2 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-2::after {
  height: 100%;
  left: 0;
  top: 0;
  width: 0;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-2:hover:after {
  width: 100%;
}

/* BUTTON 6 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-6::after {
  height: 100%;
  right: 0;
  top: 0;
  width: 0;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-6:hover:after {
  width: 100%;
}

/* BUTTON 3 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-3::after {
  height: 0;
  left: 50%;
  top: 50%;
  width: 0;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-3:hover:after {
  height: 100%;
  left: 0;
  top: 0;
  width: 100%;
}


/* BUTTON 4 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-4::before {
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-4::after {
  height: 100%;
  left: 0;
  top: 0;
  width: 100%;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-4:hover:after{
  height: 0;
  left: 50%;
  top: 50%;
  width: 0;
}


/* BUTTON 5 */
#uc_creative_buttons_elementor_0ef256c .uc_btn-5 {
  overflow: hidden;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-5::after {
  height: 100%;
  left: -100%;
  top: 0;
  transform: skew(50deg);
  transition-duration: 0.6s;
  transform-origin: top left;
  width: 0;
}

#uc_creative_buttons_elementor_0ef256c .uc_btn-5:hover:after {
  height: 100%;
  width: 200%;
}
/* end styles */

</style>


