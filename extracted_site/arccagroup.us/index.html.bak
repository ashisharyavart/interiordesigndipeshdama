				<div class="elementor-element elementor-element-9074d9f elementor-widget elementor-widget-ucaddon_fullscreen_slider" data-id="9074d9f" data-element_type="widget" data-e-type="widget" data-widget_type="ucaddon_fullscreen_slider.default">
				<div class="elementor-widget-container">
					
<!-- start fullscreen slider -->
<style>/* widget: fullscreen slider */

.carrousel-container,
.carrousel-container * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.mask {
  overflow: hidden;
}

.carrousel-container {
  --header-height: 60px;
  background: #121212;
  color: #f1f1f1;
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 100vh;
  z-index: 3;
}

.carrousel-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: brightness(0.5);
}

.carrousel-bg-item {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.carrousel-bg-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  user-select: none;
  -webkit-user-drag: none;

}

.carrousel {
  perspective: 1000px;
  position: absolute;
  overflow: hidden;
  top: calc(50%);
  left: 50%;
  transform: translate(-50%, -50%);
  width: 50%;
  max-width: 400px;
  aspect-ratio: 9/16;
  cursor: grab;
}

.carrousel-item {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
}

.carrousel-item-img {
  width: 100%;
  max-height: 100%;
  aspect-ratio: 3/4;
}

.carrousel-item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  user-select: none;
  -webkit-user-drag: none;
}

.carrousel-btns {
  width: 100%;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translate(-50%, 0%);
}

.carrousel-btns-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column-reverse;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  padding: 24px 32px;
}

.prev-next-btns {
  display: flex;
  gap: 20px;
}

.prev-next-btns div {
  text-transform: uppercase;
  font-size: 1rem;
  cursor: pointer;
}

.dots {
  display: flex;
  gap: 16px;
}

.dot {
  transition: all 0.3s ease;
  transform-origin: bottom;
  width: 4px;
  height: 30px;
  border-radius: 2px;
  background: #fff;
  opacity: 0.5;
  cursor: pointer;
}
.dot.active {
  opacity: 1;
  transform: scaleY(1.5);
}

.carrousel-header {
  width: 100%;
  position: absolute;
  top: 24px;
  left: 50%;
  transform: translate(-50%, 0%);
}

.carrousel-header-container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  gap: 4px;
  padding: 24px 32px;
  text-align: center;

  font-size: 1.2rem;
  text-transform: uppercase;
}

.carrousel-counter {
  font-size: 1.5rem;
  color: #fff;

  letter-spacing: 1rem;
}

@media (min-width: 768px) {
  .carrousel-header-container {
    flex-direction: row;
    justify-content: space-between;
  }
  .carrousel-btns-container {
    flex-direction: row;
    justify-content: space-between;
  }
  .carrousel {
 	top: calc(50% + var(--header-height));
  }
  .carrousel-header {
  	top: var(--header-height);
  }
}

</style>

