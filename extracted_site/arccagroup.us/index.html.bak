<!-- start loader curtail reveal gsap -->
<style>/* widget: loader curtail reveal gsap */

.loader {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100svh;
  z-index: 99999;
}

.loader__line {
  position: absolute;
  top: 0;
  width: 2px;
  height: 100%;
  background: #332820;
  transform: translateX(-50%);
}

.loader__line:nth-child(1) {
  left: 5%;
}
.loader__line:nth-child(2) {
  left: 95%;
}

.loader__line_thick {
  position: absolute;
  top: 0;
  left: 50%;
  width: 1px;
  height: 100%;
  background: #332820;
  transform: translateX(-50%);
}

.loader__circle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100px;
  height: 100px;
  background: #FBEEDB;
  transform: translate(-50%, -50%);
}

.loader__circle svg,
.loader__circle img{
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
}

.loader__circle img {
  padding: 0px;
}

.loader__circle svg circle {
  stroke: #332820;
}
.loader__circle svg:nth-child(2) {
  padding: 16px;
  color: #332820;
}

.curtain {
  position: fixed;
  top: 0;
  left: 0;
  width: 50vw;
  height: 100svh;
  background: #FBEEDB;
  z-index: -1;
}

.curtain:last-child {
  left: 50%;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height 64px;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1;
}

.header__content {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
}

.header__line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background:#FBEEDB
}

.header__container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 16px;
}

.header__text {
    font: 500 normal 22px/1.3 "IBM Plex Mono", monospace;
    color: #cbb295;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.header__title  {
    font: 400 normal 16px/1.3 "IBM Plex Mono", monospace;
    color: #cbb295;
    text-transform: uppercase;
    letter-spacing: 2px;
}
.header__text {
    font: 400 normal 12px/1.3 "IBM Plex Mono", monospace;
    color: #cbb295;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.header__menu {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    flex-direction: column;
    width: 40px;
}
.header__menu div {
    width: 100%;
    height: 1px;
    background: #FBEEDB
}

.hero {
  top: 0;
  left: 0;
  background: #121212;
    position: fixed;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100vw;
    height: 100svh;
}

.hero__container {
    max-width: 1200px;
    margin: 60px auto 0;
    width: 100%;
    padding: 50px 16px 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 32px;
    color: #FBEEDB
}
.hero__text {
    text-align: center;
  color: #FBEEDB
}

.hero__parraph {
    font: 500 normal 12px/1.3 "IBM Plex Mono", monospace;
    color: #cbb295;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding-top: 72px;
}

.mask {
    overflow: hidden;
}

@media (min-width: 768px) {
    .hero__parraph {
        max-width: 300px;
    margin-left: auto;
    }
}

</style>

