/* fullscreen slider scripts: */ 

gsap.registerPlugin(Observer);

window.addEventListener("DOMContentLoaded", () => {
  // --- DOM Elements ---
  const carrouselContainer = document.querySelector(".carrousel-container");
  const carrousel = document.querySelector(".carrousel");
  const items = gsap.utils.toArray(".carrousel-item");
  const bgItems = gsap.utils.toArray(".carrousel-bg-item");
  const prevBtn = document.querySelector(".prev-btn");
  const nextBtn = document.querySelector(".next-btn");
  const dotsContainer = document.querySelector(".dots");
  // craer dots con js
  items.forEach((item, i) => {
    const dot = document.createElement("div");
    dot.classList.add("dot");
    if (i === 0) dot.classList.add("active");
    dotsContainer.appendChild(dot);
  });
  const dots = gsap.utils.toArray(".dot");

  const counter = document.querySelector(".carrousel-counter");

  // --- State ---
  let currentIndex = 0;
  const totalItems = items.length;
  let isAnimating = false;
  const wrap = gsap.utils.wrap(0, totalItems); // Helper to loop indices
  const DURATION = 0.8; // Animation duration
  const EASE = "power2.inOut"; // Animation ease

  // --- Initial Setup ---
  function setupSlider() {
    // Set initial positions for items
    gsap.set(items, {
      xPercent: (i) => (i === 0 ? 0 : 100),
      scale: (i) => (i === 0 ? 1 : 0.5),
      opacity: (i) => (i === 0 ? 1 : 0),
      zIndex: (i) => (i === 0 ? 1 : 0), // Active on top initially
    });
    // Set initial image state (no parallax offset)
    gsap.set(".carrousel-item-img img", { xPercent: 0, scale: 1 });

    // Set initial positions for background items
    gsap.set(bgItems, {
      xPercent: (i) => (i === 0 ? 0 : 100),
      autoAlpha: (i) => (i === 0 ? 1 : 0),
    });

    // Set initial text positions
    gsap.set(".carrousel-item-title, .carrousel-item-subtitle", {
      yPercent: 100,
    });

    // Animate the first item's text into view
    const firstItemText = items[0].querySelectorAll(
      ".carrousel-item-title, .carrousel-item-subtitle"
    );
    gsap.to(firstItemText, {
      yPercent: 0,
      duration: 1,
      stagger: 0.1,
      ease: "power2.out",
      delay: 0.5,
    });

    updateCounter(currentIndex); // Update with initial index
    updateDots(currentIndex); // Update with initial index
  }

  // --- Core Animation Function ---
  function goToSlide(index, direction) {
    if (isAnimating) return;

    isAnimating = true;
    const newIndex = wrap(index);
    const oldIndex = currentIndex;

    // --- Update UI Immediately ---
    updateCounter(newIndex);
    updateDots(newIndex);

    const tl = gsap.timeline({
      defaults: { duration: DURATION, ease: EASE },
      onComplete: () => {
        isAnimating = false;
        currentIndex = newIndex;
        // Optional cleanup: Reset old item zIndex if needed, though setting all to 0 at start helps
        // gsap.set(items[oldIndex], { zIndex: 0 });
      },
    });

    const currentItem = items[oldIndex];
    const nextItem = items[newIndex];
    const currentBg = bgItems[oldIndex];
    const nextBg = bgItems[newIndex];
    const currentImg = currentItem.querySelector(".carrousel-item-img img");
    const nextImg = nextItem.querySelector(".carrousel-item-img img");
    const currentItemText = currentItem.querySelectorAll(
      ".carrousel-item-title, .carrousel-item-subtitle"
    );
    const nextItemText = nextItem.querySelectorAll(
      ".carrousel-item-title, .carrousel-item-subtitle"
    );

    // --- Z-Index Management ---
    gsap.set(items, { zIndex: 0 }); // Reset all first
    gsap.set(currentItem, { zIndex: 1 }); // Current item animating out
    gsap.set(nextItem, { zIndex: 2 }); // Next item animating in (on top)

    // --- Animation Logic ---

    // Background animation
    tl.to(currentBg, { xPercent: -100 * direction, autoAlpha: 0 }, 0).fromTo(
      nextBg,
      { xPercent: 100 * direction, autoAlpha: 1 },
      { xPercent: 0 },
      0
    );

    // Item text animation (out)
    tl.to(currentItemText, { yPercent: -100 * direction, stagger: 0.05 }, 0);

    // Image Parallax values
    const parallaxAmount = 15; // How much the image moves opposite (adjust as needed)
    const scaleAmount = 1.05; // Slight scale effect (adjust as needed)

    // Item animation (main transition)
    if (direction === 1) {
      // Moving NEXT (right to left visually)
      tl.to(
        currentItem,
        { xPercent: -50, scale: 0.5, opacity: 0, ease: "power2.in" },
        0
      )
        .to(
          currentImg, // Current image parallax out
          {
            xPercent: parallaxAmount,
            scale: 1 / scaleAmount,
            ease: "power2.in",
          },
          0
        )
        .fromTo(
          nextItem,
          { xPercent: 100, scale: 1, opacity: 1 }, // Start from right
          { xPercent: 0, ease: "power2.out" },
          0
        )
        .fromTo(
          nextImg, // Next image parallax in
          { xPercent: -parallaxAmount, scale: scaleAmount },
          { xPercent: 0, scale: 1, ease: "power2.out" },
          0
        );
    } else {
      // Moving PREV (left to right visually)
      tl.to(currentItem, { xPercent: 100, ease: "power2.in" }, 0) // Move current off right
        .to(
          currentImg, // Current image parallax out
          {
            xPercent: -parallaxAmount,
            scale: 1 / scaleAmount,
            ease: "power2.in",
          },
          0
        )
        .fromTo(
          nextItem,
          { xPercent: -50, scale: 0.5, opacity: 0 }, // Start from left, scaled down
          { xPercent: 0, scale: 1, opacity: 1, ease: "power2.out" },
          0
        )
        .fromTo(
          nextImg, // Next image parallax in
          { xPercent: parallaxAmount, scale: scaleAmount },
          { xPercent: 0, scale: 1, ease: "power2.out" },
          0
        );
    }

    // Item text animation (in) - delayed slightly
    tl.fromTo(
      nextItemText,
      { yPercent: 100 * direction },
      { yPercent: 0, stagger: 0.05 },
      DURATION * 0.2 // Start text animation slightly after item starts moving
    );
  }

  // --- Helper Functions ---
  function updateCounter(index) {
    // Accept index
    counter.textContent = `${index + 1}/${totalItems}`;
  }

  function updateDots(index) {
    // Accept index
    dots.forEach((dot, i) => {
      dot.classList.toggle("active", i === index);
    });
  }

  // --- Event Listeners ---
  nextBtn.addEventListener("click", () => goToSlide(currentIndex + 1, 1));
  prevBtn.addEventListener("click", () => goToSlide(currentIndex - 1, -1));

  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      if (i !== currentIndex && !isAnimating) {
        const direction = i > currentIndex ? 1 : -1;
        // Handle wrap around case for direction calculation if needed, though goToSlide handles index wrap
        if (currentIndex === totalItems - 1 && i === 0) {
          goToSlide(i, 1); // Explicitly next
        } else if (currentIndex === 0 && i === totalItems - 1) {
          goToSlide(i, -1); // Explicitly prev
        } else {
          goToSlide(i, direction);
        }
      }
    });
  });

  // --- Observer for Scroll/Drag ---
  Observer.create({
    target: carrousel,
    type: "wheel,touch,pointer",
    wheelSpeed: 1,
    tolerance: 15, // Slightly increased tolerance
    preventDefault: true,
    onLeft: () => goToSlide(currentIndex + 1, 1),
    onRight: () => goToSlide(currentIndex - 1, -1),
  });

  // --- Initialize ---
  setupSlider();
});

/* Ax Cursor Effect scripts: */ 

const cursor = document.querySelector('#uc_ax_cursor_effect_elementor_d0cdf09');
const cursorCircle = cursor.querySelector('.cursor__circle');

const mouse = { x: -100, y: -100 }; // mouse pointer's coordinates
const pos = { x: 0, y: 0 }; // cursor's coordinates
const speed = 0.1; // between 0 and 1

const updateCoordinates = e => {
  mouse.x = e.clientX;
  mouse.y = e.clientY;
}

window.addEventListener('mousemove', updateCoordinates);


function getAngle(diffX, diffY) {
  return Math.atan2(diffY, diffX) * 180 / Math.PI;
}

function getSqueeze(diffX, diffY) {
  const distance = Math.sqrt(
    Math.pow(diffX, 2) + Math.pow(diffY, 2)
  );
  const maxSqueeze = 0.15;
  const accelerator = 1500;
  return Math.min(distance / accelerator, maxSqueeze);
}


const updateCursor = () => {
  const diffX = Math.round(mouse.x - pos.x);
  const diffY = Math.round(mouse.y - pos.y);
  
  pos.x += diffX * speed;
  pos.y += diffY * speed;
  
  const angle = getAngle(diffX, diffY);
  const squeeze = getSqueeze(diffX, diffY);
  
  const scale = 'scale(' + (1 + squeeze) + ', ' + (1 - squeeze) +')';
  const rotate = 'rotate(' + angle +'deg)';
  const translate = 'translate3d(' + pos.x + 'px ,' + pos.y + 'px, 0)';

  cursor.style.transform = translate;
  cursorCircle.style.transform = rotate + scale;
};

function loop() {
  updateCursor();
  requestAnimationFrame(loop);
}

requestAnimationFrame(loop);



const cursorModifiers = document.querySelectorAll('[cursor-class]');

cursorModifiers.forEach(curosrModifier => {
  curosrModifier.addEventListener('mouseenter', function() {
    const attribute = this.getAttribute('cursor-class');
    cursor.classList.add(attribute);
  });
  
  curosrModifier.addEventListener('mouseleave', function() {
    const attribute = this.getAttribute('cursor-class');
    cursor.classList.remove(attribute);
  });
});
</script>
<script type='module'>

/* Texto reveal scripts: */ 

gsap.registerPlugin(ScrollTrigger, SplitText);

window.addEventListener("DOMContentLoaded", () => {
  // When all the fonts are loaded
  document.fonts.ready.then(() => {
    init();
  });
});

function init() {
   const paragraph = document.querySelector(".p-10");
   const {lines} = new SplitText(paragraph, {type: "lines", linesClass: "line"});
  
  lines.forEach(line => {
    const originalLine = line;
    line.outerHTML = `<div class="mask">${originalLine.outerHTML}</div>`
  })

  //now animate each character into place from 100px above, fading in:
  gsap.from( `.p-10 .line`, {
    y: "100%",
    stagger: 0.01,
    duration: 1.6,
    delay: 0,
    scrollTrigger: {
      trigger: `.p-10`,
      start: "top bottom",
      end: "bottom end",
      toggleActions: "play none none none",
    },
  });
}
</script>
